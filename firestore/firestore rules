rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── HELPERS ──
    function isAdmin() {
      return request.auth != null 
             && request.auth.token.email == "jmlsd75@gmail.com";
    }

    function isOwner(email) {
      return request.auth != null 
             && request.auth.token.email == email;
    }

    // ── USERS ──
    match /users/{email} {
      // Admin can READ all users
      allow read: if isAdmin();

      // Admin can UPDATE any user (ban, unban, flag, etc.)
      allow update: if isAdmin();

      // User can read their own doc
      allow read: if isOwner(email);

      // User can create/update their own doc
      allow create, update: if isOwner(email);
    }

    // ── PAYMENTS ──
    match /payments/{paymentId} {
      // Only admin reads/writes payments
      allow read, write: if isAdmin();

      // User can read their own payments
      allow read: if request.auth != null 
                  && request.resource.data.userEmail == request.auth.token.email;
    }

    // ── SPACES ──
    match /spaces/{spaceId} {
      // Admin full access
      allow read, write: if isAdmin();

      // Logged-in users can read
      allow read: if request.auth != null;
    }

    // ── DANGEROUS ACCOUNTS ──
    match /dangerous_accounts/{accountId} {
      // Only admin — this is sensitive
      allow read, write: if isAdmin();
    }

    // ── REPORTS (if you add reporting) ──
    match /reports/{reportId} {
      allow read, write: if isAdmin();
      allow create: if request.auth != null;
    }
  }
}
