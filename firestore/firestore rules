rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── HELPERS ──
    // Hardcoded admin is fine for small apps, but remember to change it here if your email ever changes!
    function isAdmin() {
      return request.auth != null 
             && request.auth.token.email == "jmlsd75@gmail.com";
    }

    // ── USERS ──
    match /users/{userId} {
      // Admin can read/update any user
      allow read, update: if isAdmin();
      
      // Users can read/update/create ONLY their own document using their Auth UID
      allow get, create, update: if request.auth != null 
                                 && request.auth.uid == userId;
    }

    // ── PAYMENTS ──
    match /payments/{paymentId} {
      // Admin has full access
      allow read, write: if isAdmin();

      // Users can read their own payments
      allow read: if request.auth != null 
               && resource.data.userEmail == request.auth.token.email;
    }

    // ── SPACES (metadata only) ──
    match /spaces/{spaceId} {
      // Admin can read all space usage metadata
      allow read: if isAdmin();
      
      // Users can read their own space usage
      allow get: if request.auth != null 
              && resource.data.userEmail == request.auth.token.email;

      // Default deny handles update, create, delete (no need for 'if false')
    }

    // ── DANGEROUS ACCOUNTS ──
    match /dangerous_accounts/{accountId} {
      allow read, write: if isAdmin();
    }

    // ── REPORTS ──
    match /reports/{reportId} {
      allow read, update, delete: if isAdmin();
      
      // Users can create reports, but we force the 'reportedBy' field to be their actual email
      allow create: if request.auth != null 
                    && request.resource.data.reportedBy == request.auth.token.email;
    }
  }
}
