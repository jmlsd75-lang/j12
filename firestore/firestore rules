rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── HELPERS ──
    function isAdmin() {
      return request.auth != null 
             && request.auth.token.email == "jmlsd75@gmail.com";
    }

    function isOwner(email) {
      return request.auth != null 
             && request.auth.token.email == email;
    }

    // ── USERS ──
    match /users/{userId} {
      // Admin can read all users metadata (like spaceUsed, lastVisit, lastPayment)
      allow get, list: if isAdmin();
      
      // Admin can update any user (e.g., flag, ban)
      allow update: if isAdmin();

      // Users can read/update only their own document
      allow get, update, create: if isOwner(userId);
    }

    // ── PAYMENTS ──
    match /payments/{paymentId} {
      // Only admin reads/writes payments
      allow get, list, create, update, delete: if isAdmin();

      // User can read their own payments
      allow get, list: if request.auth != null 
                      && resource.data.userEmail == request.auth.token.email;
    }

    // ── SPACES (metadata only) ──
    match /spaces/{spaceId} {
      // Admin can read all space usage metadata
      allow get, list: if isAdmin();
      
      // Users can read their own space usage
      allow get: if request.auth != null && resource.data.userEmail == request.auth.token.email;

      // No one can write actual file content here — only metadata is allowed
      allow update, create, delete: if false;
    }

    // ── DANGEROUS ACCOUNTS ──
    match /dangerous_accounts/{accountId} {
      allow get, list, update, create, delete: if isAdmin();
    }

    // ── REPORTS ──
    match /reports/{reportId} {
      allow get, list, update, delete: if isAdmin();
      allow create: if request.auth != null;
    }
  }
}
