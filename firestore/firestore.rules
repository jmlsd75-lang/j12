rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Timer doc rules (same as before)
    match /userTimers/{docId} {
      allow read, write: if request.auth != null
                         && request.auth.token.email.replace('.', '_') == docId;
    }

    // Tab tracking rules (allows subcollections)
    match /userTabs/{docId}/active/{tabId} {
      allow read, write: if request.auth != null
                         && request.auth.token.email.replace('.', '_') == docId;
    }

    // Block everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
